<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    VIEW FOR OWNERS    -->
    <record id="views_tennis_center_list" model="ir.ui.view">
        <field name="name">Tennis Center Owner</field>
        <field name="model">tennis.center</field>
        <field name="groups_id" eval="[4, ref('tennis.group_tennis_owner')]"/>
        <field name="arch" type="xml">
            <list string="Теннисные центры">
                <field name="name"/>
                <field name="address"/>
                <field name="manager_id"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
            </list>
        </field>
    </record>

    <record id="view_tennis_center_form" model="ir.ui.view">
        <field name="name">tennis.center.form</field>
        <field name="model">tennis.center</field>
        <field name="arch" type="xml">
            <form string="Теннисный центр">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Название центра (например, 'Сет и Мат')"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Основная информация">
                            <field name="address"/>
                            <field name="owner_id" readonly="1"/>
                            <field name="manager_id"/>
                            <field name="court"/>
                        </group>
                        <group string="Режим работы">
                            <label for="start_time" string="Opening hours"/>
                            <div class="o_row">
                                <field name="start_time" widget="float_time"/>
                                <span>до</span>
                                <field name="end_time" widget="float_time"/>
                            </div>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--    INVITATION FOR MANAGER     -->
    <record id="email_template_manager_invitation" model="mail.template">
        <field name="name">Tennis Center: Manager Assignment</field>
        <field name="model_id" ref="model_tennis_center"/>
        <field name="subject">Вы назначены менеджером в {{ object.name }}</field>
        <field name="email_from">{{ (object.owner_id.email_formatted or user.email_formatted) }}</field>
        <field name="email_to">{{ object.manager_id.work_email or object.manager_id.email }}</field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p>Приветствую,<t t-out="object.manager_id.name"/>!
                </p>
                <p>Сообщаем вам, что вы назначены ответственным менеджером теннисного центра
                    <strong>
                        <t t-out="object.name"/>
                    </strong>
                    .
                    <div style="margin: 20px 0px;">
                        <a t-att-href="object.get_base_url() + '/tennis/accept_invitation/' + str(object.id)"
                           style="background-color: #875A7B; padding: 12px 24px; text-decoration: none; color: white; border-radius: 5px; font-weight: bold;">
                            Подтвердить роль менеджера
                        </a>
                    </div>
                </p>
                <p>Адрес центра:
                    <t t-out="object.address"/>
                </p>
                <br/>
                <p>С уважением, команда управления кортами.</p>
            </div>
        </field>
    </record>

    <record id="action_send_manager_invitation" model="ir.actions.server">
        <field name="name">Send Manager Invitation</field>
        <field name="model_id" ref="model_tennis_center"/>
        <field name="state">code</field>
        <field name="code">
            if record.manager_id:
            template = env.ref('tennis.email_template_manager_invitation')
            template.send_mail(record.id, force_send=True)
        </field>
    </record>

    <record id="rule_on_manager_assignment" model="base.automation">
        <field name="name">Tennis: Send Invite on Manager Assign</field>
        <field name="model_id" ref="model_tennis_center"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(4, ref('tennis.field_tennis_center__manager_id'))]"/>
        <field name="action_server_ids" eval="[(4, ref('tennis.action_send_manager_invitation'))]"/>
    </record>

    <record id="action_tennis_center" model="ir.actions.act_window">
        <field name="name">Tennis Center</field>
        <field name="res_model">tennis.center</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>