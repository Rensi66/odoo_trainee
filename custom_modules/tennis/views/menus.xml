<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_tennis_entrance_check" model="ir.actions.server">
        <field name="name">action.tennis.entrance.check</field>
        <field name="model_id" ref="model_tennis_center"/>
        <field name="state">code</field>
        <field name="code">
