<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_act_window" model="ir.actions.act_window">
        <field name="name">Action act_window</field>
        <field name="res_model">model.for.actions</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create the first record</p>
        </field>
    </record>

    <record id="action_for_act_url" model="ir.actions.act_url">
        <field name="name">My GitHub</field>
        <field name="url">https://github.com/Rensi66</field>
        <field name="target">new</field>
    </record>

    <record id="action_for_client" model="ir.actions.client">
        <field name="name">My dashboard</field>
        <field name="tag">my_custom_client_action_tag</field>
        <field name="target">current</field>
    </record>

    <record id="action_for_server" model="ir.actions.server">
        <field name="name">Action server</field>
        <field name="model_id" ref="lesson_4.model_model_for_actions"/>
        <field name="binding_model_id" ref="lesson_4.model_model_for_actions"/>
        <field name="state">code</field>
        <field name="code">
            for record in records:
                record.write({'field1': (record.field1 or "") + " - this field updated"})
        </field>
    </record>

    <record id="action_for_report" model="ir.actions.report">
        <field name="name">My report</field>
        <field name="model">model.for.actions</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">lesson_4.report_test_template</field>
        <field name="binding_model_id" ref="lesson_4.model_model_for_actions"/>
    </record>

    <template id="report_test_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h1>PDF отчет</h1>
                        <p>Запись: <span t-field="o.display_name"/></p>
                        <p>Данные из поля field1: <span t-field="o.field1"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>