<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="project_res_partner_form" model="ir.ui.view">
        <field name="name">project.res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='child_ids']/kanban" position="inside">
                <field name="is_primary"/>
            </xpath>

            <xpath expr="//field[@name='child_ids']/kanban//t[@t-name='card']//main" position="inside">
                <div class="position-absolute top-0 end-0 text-danger p-2">
                    <button type="object"
                            name="action_toggle_is_primary"
                            class="btn p-0 text-danger border-0 o_kanban_no_action"
                            style="background: none; box-shadow: none;">
                        <i t-if="record.is_primary.raw_value" class="fa fa-check-square"/>
                        <i t-if="!record.is_primary.raw_value" class="fa fa-square-o"/>
                    </button>
                </div>
            </xpath>

            <xpath expr="//field[@name='child_ids']/form//field[@name='function']" position="after">
                <field name="is_primary"/>
            </xpath>
        </field>
    </record>
</odoo>