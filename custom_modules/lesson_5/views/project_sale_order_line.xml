<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="project_sale_order_line_inherit" model="ir.ui.view">
        <field name="name">project.sale.order.line.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='order_lines']/field[@name='order_line']/list/field[@name='tax_id']" position="after">
                <button name="action_open_split_wizard"
                        type="object"
                        icon="fa-scissors"
                        class="btn-link"/>
            </xpath>
        </field>
    </record>
</odoo>