<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_custom_form" model="ir.ui.view">
        <field name="name">custom.form.view</field>
        <field name="model">lesson1.main.model</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_company" string="Create Person" type="object" invisible="is_company"/>
                    <button name="action_create_company" string="Create Company" type="object" invisible="not is_company"/>
                    <button name="action_create_partner" string="CREATE PARTNER" type="object"/>
                </header>

                <sheet>
                    <group string="Основные поля">
                        <field name="text"/>
                        <field name="check1"/>
                        <field name="check2"/>
                        <field name="check_all"/>
                    </group>

                    <group string="Поля после создания" invisible="not id">
                        <field name="select1"/>
                        <field name="select2"/>
                        <field name="int_field"/>
                        <field name="float_field"/>
                        <field name="currency_id"/>
                        <field name="money_field"/>
                        <field name="date_field"/>
                        <field name="date_time_field"/>
                        <field name="file_field"/>
                        <field name="image_field"/>

                        <group string="Пятая таска">
                            <field name="boolean1" invisible="select1 != '1' and select2 != '1'"/>
                            <field name="boolean2" invisible="select1 != '1' and select2 != '2'"/>
                            <field name="boolean3" invisible="select1 != '1' and select2 != '3'"/>

                            <field name="boolean4" invisible="select1 != '2' and select2 != '1'"/>
                            <field name="boolean5" invisible="select1 != '2' and select2 != '2'"/>
                            <field name="boolean6" invisible="select1 != '2' and select2 != '3'"/>

                            <field name="boolean7" invisible="select1 != '3' and select2 != '1'"/>
                            <field name="boolean8" invisible="select1 != '3' and select2 != '2'"/>
                            <field name="boolean9" invisible="select1 != '3' and select2 != '3'"/>
                        </group>
                    </group>

                    <group string="Проверка на компанию" invisible="not id">
                        <field name="is_company"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>