<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="order_line_view" model="ir.ui.view">
        <field name="name">order.line.view</field>
        <field name="model">model.order</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="order_no"/>
                    <field name="line_ids">
                        <tree editable="bottom">
                            <field name="product_name"/>
                            <field name="unit_price"/>
                            <field name="count"/>
                            <field name="subtotal"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
</odoo>